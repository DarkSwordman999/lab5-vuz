#!/bin/bash

# =============================================
# ЛАБОРАТОРНАЯ РАБОТА №8 - ВУЗ
# Скрипт для запуска отчётов на Python
# =============================================

show_help() {
    echo "============================================="
    echo "  ЛАБОРАТОРНАЯ РАБОТА №8 - ВУЗ"
    echo "============================================="
    echo ""
    echo "КОМАНДЫ:"
    echo "  ./PYTHON 1 [группа] [дисциплина]   - отчёт по группам и дисциплинам"
    echo "  ./PYTHON 2 [группа]                - сводная таблица"
    echo "  ./PYTHON 3                         - график динамики"
    echo "  ./PYTHON 4 [группа]                - круговая диаграмма"
    echo "  ./PYTHON all                       - выполнить всё"
    echo "  ./PYTHON save                      - сохранить все графики"
    echo "  ./PYTHON save --force              - сохранить с перезаписью"
    echo ""
    echo "ПРИМЕРЫ:"
    echo "  ./PYTHON 1"
    echo "  ./PYTHON 1 ИНФ-101"
    echo "  ./PYTHON 1 ИНФ-101 Программирование"
    echo "  ./PYTHON 2"
    echo "  ./PYTHON 2 ИНФ"
    echo "  ./PYTHON 3"
    echo "  ./PYTHON 4"
    echo "  ./PYTHON 4 ИНФ"
    echo "  ./PYTHON save --force"
}

case "$1" in
    1)
        if [ -z "$2" ]; then
            echo " Отчёт по всем группам и дисциплинам..."
            python3 lab8_report_fixed.py task1
        elif [ -z "$3" ]; then
            echo " Отчёт по группе: $2..."
            python3 lab8_report_fixed.py task1 "$2"
        else
            echo " Отчёт по группе: $2, дисциплина: $3..."
            python3 lab8_report_fixed.py task1 "$2" "$3"
        fi
        ;;
    2)
        if [ -z "$2" ]; then
            echo " Сводная таблица по всем группам..."
            python3 lab8_report_fixed.py task2
        else
            echo " Сводная таблица по группам, содержащим: $2..."
            python3 lab8_report_fixed.py task2 "$2"
        fi
        ;;
    3)
        if [ "$2" = "--force" ]; then
            echo " График динамики (перезапись)..."
            python3 lab8_chart.py task3 --force
        else
            echo " График динамики..."
            python3 lab8_chart.py task3
        fi
        ;;
    4)
        if [ -z "$2" ]; then
            echo " Круговая диаграмма по всем группам..."
            python3 lab8_chart.py task4
        elif [ "$2" = "--force" ]; then
            echo " Круговая диаграмма (перезапись)..."
            python3 lab8_chart.py task4 --force
        elif [ "$3" = "--force" ]; then
            echo " Круговая диаграмма для групп, содержащих: $2 (перезапись)..."
            python3 lab8_chart.py task4 "$2" --force
        else
            echo " Круговая диаграмма для групп, содержащих: $2..."
            python3 lab8_chart.py task4 "$2"
        fi
        ;;
    save)
        if [ "$2" = "--force" ]; then
            echo " Сохранение всех графиков (перезапись)..."
            python3 lab8_chart.py save-all --force
        else
            echo " Сохранение всех графиков..."
            python3 lab8_chart.py save-all
        fi
        ;;
    all)
        echo "============================================="
        echo "  ВЫПОЛНЕНИЕ ВСЕХ ЗАДАЧ"
        echo "============================================="
        echo ""
        echo "--- ЗАДАЧА 1: ОТЧЁТ ---"
        python3 lab8_report_fixed.py task1
        echo ""
        echo "--- ЗАДАЧА 2: СВОДНАЯ ТАБЛИЦА ---"
        python3 lab8_report_fixed.py task2
        echo ""
        echo "--- ЗАДАЧА 3: ГРАФИК ---"
        python3 lab8_chart.py task3
        echo ""
        echo "--- ЗАДАЧА 4: ДИАГРАММА ---"
        python3 lab8_chart.py task4
        ;;
    *)
        show_help
        ;;
esac
